// 控制流程
// 展示：如果/否則、當迴圈

整數 成績 = 85;

// if-else 條件分支
印出("成績: ", 成績);
如果 (成績 >= 90) {
    印出("等級: A");
} 否則 {
    如果 (成績 >= 80) {
        印出("等級: B");
    } 否則 {
        如果 (成績 >= 70) {
            印出("等級: C");
        } 否則 {
            如果 (成績 >= 60) {
                印出("等級: D");
            } 否則 {
                印出("等級: F");
            }
        }
    }
}

// while 迴圈
印出("--- while 迴圈 ---");
整數 計數 = 1;
當 (計數 <= 5) {
    印出("計數: ", 計數);
    計數 = 計數 + 1;
}

// 巢狀 if-else
整數 x = 10;
整數 y = 20;
如果 (x > 0) {
    如果 (y > 0) {
        印出("x 與 y 皆為正數");
    } 否則 {
        印出("x 為正數，y 為非正數");
    }
} 否則 {
    印出("x 為非正數");
}
