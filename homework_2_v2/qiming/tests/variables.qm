// 變數宣告與型別
// 展示：所有基礎型別、變數賦值、運算式

// 整數型別
整數 年齡 = 25;
整數 年份 = 2026;
整數 數量 = -10;

// 小數型別
小數 圓周率 = 3.14159;
小數 半徑 = 5.0;
小數 面積 = 圓周率 * 半徑 * 半徑;

// 布林型別
布林 是學生 = 真;
布林 已畢業 = 假;

// 字串型別
字串 姓名 = "黃信惟";
字串 學校 = "金門大學";
字串 問候 = "你好，";

// 印出結果
印出("姓名: ", 姓名);
印出("年齡: ", 年齡);
印出("面積: ", 面積);
印出("是學生: ", 是學生);
