// 運算子
// 展示：算術運算、比較運算

整數 a = 15;
整數 b = 4;

// 算術運算
整數 加 = a + b;
整數 減 = a - b;
整數 乘 = a * b;
整數 除 = a / b;
整數 餘 = a % b;

印出("a + b = ", 加);
印出("a - b = ", 減);
印出("a * b = ", 乘);
印出("a / b = ", 除);
印出("a % b = ", 餘);

// 比較運算
布林 相等 = a == b;
布林 不相等 = a != b;  // TODO: != 待實作
布林 小於 = a < b;
布林 小於等於 = a <= b;
布林 大於 = a > b;
布林 大於等於 = a >= b;

印出("a == b: ", 相等);
印出("a < b: ", 小於);
印出("a <= b: ", 小於等於);
印出("a > b: ", 大於);
印出("a >= b: ", 大於等於);

// 複合運算式
整數 結果 = (a + b) * (a - b) / 2;
印出("(a+b)*(a-b)/2 = ", 結果);
