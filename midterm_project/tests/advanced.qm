// 進階運算與函式組合
// 展示：多個函式定義、彼此呼叫、複雜運算式

// 最大公因數（輾轉相除法）
整數 最大公因數(整數 a, 整數 b) {
    如果 (b == 0) {
        回傳 a;
    } 否則 {
        回傳 最大公因數(b, a % b);
    }
}

// 最小公倍數
整數 最小公倍數(整數 a, 整數 b) {
    回傳 (a * b) / 最大公因數(a, b);
}

// 絕對值
整數 絕對值(整數 x) {
    如果 (x < 0) {
        回傳 -x;
    } 否則 {
        回傳 x;
    }
}

整數 a = 12;
整數 b = 18;

印出("a = ", a, ", b = ", b);
印出("最大公因數: ", 最大公因數(a, b));
印出("最小公倍數: ", 最小公倍數(a, b));

整數 負數 = -42;
印出("|-42| = ", 絕對值(負數));

// 組合運算
整數 結果 = 最大公因數(24, 36) + 最小公倍數(10, 15);
印出("gcd(24,36) + lcm(10,15) = ", 結果);
