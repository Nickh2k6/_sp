// 遞迴函式：費氏數列 + 迴圈求和
// 展示：遞迴、函式呼叫、迴圈、變數更新、多參數印出

整數 費氏數列(整數 項數) {
    如果 (項數 <= 1) {
        回傳 項數;
    } 否則 {
        回傳 費氏數列(項數 - 1) + 費氏數列(項數 - 2);
    }
}

整數 總和 = 0;
整數 計數 = 1;
當 (計數 <= 10) {
    總和 = 總和 + 計數;
    計數 = 計數 + 1;
}

印出("1加到10的總和為: ", 總和);
印出("費氏數列第10項為: ", 費氏數列(10));

// 列出前 10 項費氏數列
印出("--- 費氏數列前 10 項 ---");
印出("第 1 項: ", 費氏數列(1));
印出("第 2 項: ", 費氏數列(2));
印出("第 3 項: ", 費氏數列(3));
印出("第 4 項: ", 費氏數列(4));
印出("第 5 項: ", 費氏數列(5));
印出("第 6 項: ", 費氏數列(6));
印出("第 7 項: ", 費氏數列(7));
印出("第 8 項: ", 費氏數列(8));
印出("第 9 項: ", 費氏數列(9));
印出("第 10 項: ", 費氏數列(10));
