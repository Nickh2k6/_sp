// 質數判斷
// 展示：布林回傳值、迴圈內條件判斷、巢狀控制流程

布林 是質數(整數 n) {
    如果 (n <= 1) {
        回傳 假;
    }
    整數 i = 2;
    當 (i < n) {
        如果 (n % i == 0) {
            回傳 假;
        }
        i = i + 1;
    }
    回傳 真;
}

// 輸出 1 到 20 之間的質數
整數 數 = 1;
印出("1 到 20 之間的質數:");
當 (數 <= 20) {
    如果 (是質數(數)) {
        印出(數);
    }
    數 = 數 + 1;
}

// 質數個數統計
整數 上限 = 30;
整數 總質數 = 0;
整數 當前 = 2;
當 (當前 <= 上限) {
    如果 (是質數(當前)) {
        總質數 = 總質數 + 1;
    }
    當前 = 當前 + 1;
}
印出("1 到 30 共有 ", 總質數, " 個質數");
